# AI Provider: claude | codex（默认 claude）
AI_PROVIDER=claude

# Claude API（AI_PROVIDER=claude 时使用）
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=https://your-proxy.com/v1  # 可选，代理地址

# Codex API（AI_PROVIDER=codex 时使用）
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=  # 可选，代理地址
# CODEX_API_KEY=  # 也可以用这个

# 飞书应用
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# 启动通知（可选）
# 填 open_id (ou_xxx) 或 chat_id (oc_xxx)
# 先运行一次，给机器人发消息，从日志获取 ID
NOTIFY_USER_ID=oc_5ae3fe37efdbac19b76ec763db921d67

# 飞书输出模式：card（单卡片更新）| reply（按原消息逐条回复）
# 默认 reply：更像普通聊天记录
# FEISHU_OUTPUT_MODE=reply

# reply 模式消息格式：md（默认，post 富文本 md 节点）| text（纯文本）
# FEISHU_REPLY_FORMAT=md

# reply 模式细节开关（默认全部开启）
# FEISHU_REPLY_SHOW_TOOL_CALLS=true
# FEISHU_REPLY_SHOW_TOOL_INPUT=true
# FEISHU_REPLY_SHOW_TOOL_RESULT=true
# FEISHU_REPLY_SHOW_USAGE=true
# FEISHU_REPLY_SHOW_QUEUE_NOTICE=true

# reply 模式收到消息后给用户消息打 reaction（默认开启）
# FEISHU_REPLY_ACK_REACTION=true
# FEISHU_REPLY_ACK_EMOJI=OK

# 工作目录（Docker 中映射的目录）
WORKSPACE=/workspace

# 开发者目录特例（可选）
# 当私聊发送者 open_id 命中时，直接使用本机目录
# DEVELOPER_OPEN_ID=ou_xxx
# DEVELOPER_WORKSPACE=/Users/yourname

# 单轮会话超时（毫秒，可选，默认 10 分钟）
# CHAT_TURN_TIMEOUT_MS=600000
